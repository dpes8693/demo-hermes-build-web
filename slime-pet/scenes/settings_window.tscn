[ext_resource type="Script" uid="uid://d4nfm7b042m4r" path="res://scripts/settings_window.gd" id="1_settings"]

[node name="SettingsWindow" type="Window"]
title = "設定"
size = Vector2i(560, 900)
min_size = Vector2i(480, 820)
visible = false
exclusive = false
script = ExtResource("1_settings")

[node name="Margin" type="MarginContainer" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/margin_left = 16
theme_override_constants/margin_top = 16
theme_override_constants/margin_right = 16
theme_override_constants/margin_bottom = 16

[node name="VBox" type="VBoxContainer" parent="Margin"]
layout_mode = 2
theme_override_constants/separation = 10

[node name="ExportDirField" type="VBoxContainer" parent="Margin/VBox"]
layout_mode = 2
theme_override_constants/separation = 2

[node name="Label" type="Label" parent="Margin/VBox/ExportDirField"]
layout_mode = 2
text = "輸出資料夾（Claude 排程端指向這裡讀取）"

[node name="DirRow" type="HBoxContainer" parent="Margin/VBox/ExportDirField"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 6

[node name="ExportDir" type="LineEdit" parent="Margin/VBox/ExportDirField/DirRow"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
placeholder_text = "例如 /Users/you/Documents/SlimePet"

[node name="OpenDirBtn" type="Button" parent="Margin/VBox/ExportDirField/DirRow"]
unique_name_in_owner = true
layout_mode = 2
text = "開啟"

[node name="IntervalField" type="VBoxContainer" parent="Margin/VBox"]
layout_mode = 2
theme_override_constants/separation = 2

[node name="Label" type="Label" parent="Margin/VBox/IntervalField"]
layout_mode = 2
text = "取樣間隔"

[node name="Interval" type="SpinBox" parent="Margin/VBox/IntervalField"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
min_value = 5.0
max_value = 3600.0
step = 5.0
value = 5.0
suffix = " 秒"

[node name="WorkHoursField" type="VBoxContainer" parent="Margin/VBox"]
layout_mode = 2
theme_override_constants/separation = 2

[node name="Label" type="Label" parent="Margin/VBox/WorkHoursField"]
layout_mode = 2
text = "每日預計工時（寫進報告供總結參考）"

[node name="WorkHours" type="SpinBox" parent="Margin/VBox/WorkHoursField"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
min_value = 1.0
max_value = 24.0
step = 0.5
value = 1.0
suffix = " 小時"

[node name="SlimeSizeField" type="VBoxContainer" parent="Margin/VBox"]
layout_mode = 2
theme_override_constants/separation = 2

[node name="Label" type="Label" parent="Margin/VBox/SlimeSizeField"]
layout_mode = 2
text = "史萊姆大小（存檔即時生效，不需重啟）"

[node name="SlimeSize" type="SpinBox" parent="Margin/VBox/SlimeSizeField"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
min_value = 50.0
max_value = 200.0
step = 10.0
value = 100.0
suffix = " %"

[node name="Tracking" type="CheckBox" parent="Margin/VBox"]
unique_name_in_owner = true
layout_mode = 2
text = "啟用背景追蹤（記錄前景視窗）"

[node name="Screenshot" type="CheckBox" parent="Margin/VBox"]
unique_name_in_owner = true
layout_mode = 2
text = "啟用螢幕截圖 + 本機 OCR（圖片不上傳，只留辨識文字）"

[node name="OcrLangField" type="VBoxContainer" parent="Margin/VBox"]
layout_mode = 2
theme_override_constants/separation = 2

[node name="Label" type="Label" parent="Margin/VBox/OcrLangField"]
layout_mode = 2
text = "OCR 語言（Tesseract，需裝對應語言包）"

[node name="OcrLang" type="LineEdit" parent="Margin/VBox/OcrLangField"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
