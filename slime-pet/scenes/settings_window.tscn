[node name="KeepShots" type="CheckBox" parent="Margin/VBox"]
unique_name_in_owner = true
layout_mode = 2
text = "保留截圖檔（預設關閉；OCR 完即刪以省空間／保護隱私）"

[node name="RestPeriodsField" type="VBoxContainer" parent="Margin/VBox"]
layout_mode = 2
theme_override_constants/separation = 2

[node name="Label" type="Label" parent="Margin/VBox/RestPeriodsField"]
layout_mode = 2
text = "休息時段（暫停取樣；每行一條，行首寫星期幾可覆寫該日）"

[node name="RestPeriods" type="TextEdit" parent="Margin/VBox/RestPeriodsField"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
custom_minimum_size = Vector2(0, 84)
placeholder_text = "12:00-13:00, 18:00-08:00\n二 12:00-17:00      ← 週二晚上工作，只休下午\n六日                 ← 週末整天取樣（空 = 全天取樣）"

[node name="KeepDaysField" type="VBoxContainer" parent="Margin/VBox"]
layout_mode = 2
theme_override_constants/separation = 2

[node name="Label" type="Label" parent="Margin/VBox/KeepDaysField"]
layout_mode = 2
text = "截圖保留天數（超過自動清理；0 = 永久保留）"

[node name="KeepDays" type="SpinBox" parent="Margin/VBox/KeepDaysField"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
min_value = 0.0
max_value = 365.0
step = 1.0
value = 14.0
suffix = " 天"

[node name="OcrStatus" type="Label" parent="Margin/VBox"]
unique_name_in_owner = true
layout_mode = 2

[node name="AccessibilityStatus" type="Label" parent="Margin/VBox"]
unique_name_in_owner = true
layout_mode = 2
