text = "這個 App 只負責記錄：寫出 activity/*.json 與 reports/report-*.md。總結交給 Claude 的本機排程任務去讀這個資料夾產生。截圖只在本機 OCR、永不上傳。"
autowrap_mode = 3

[node name="Status" type="Label" parent="Margin/VBox"]
unique_name_in_owner = true
layout_mode = 2
