; Engine configuration file.
; Godot 4.3+  —  桌寵史萊姆 Slime Pet
;
; To open: Godot Engine 4.3 or newer  ->  Import  ->  pick this project.godot

config_version=5

[application]

config/name="桌寵史萊姆 Slime Pet"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.3", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

Config="*res://scripts/config.gd"
Store="*res://scripts/store.gd"
Platform="*res://scripts/platform.gd"
Tracker="*res://scripts/tracker.gd"

[display]

window/size/viewport_width=240
window/size/viewport_height=240
window/size/borderless=true
window/size/transparent=true
window/size/always_on_top=true
window/per_pixel_transparency/allowed=true
window/subwindows/embed_subwindows=false

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
anti_aliasing/quality/msaa_2d=2
textures/canvas_textures/default_texture_filter=1
